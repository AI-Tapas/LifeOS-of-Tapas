# Copy to .env.local for local dev. Get local values from: supabase status
# For production (Vercel), use the Supabase cloud project's values.

# Supabase project URL (local: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key. Safe for the client; RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER SIDE ONLY, never expose to the client and never
# set it as a NEXT_PUBLIC_ variable. Used only by scripts/rls.test.mjs in
# this milestone (the test can also read it from supabase status itself).
SUPABASE_SERVICE_ROLE_KEY=
