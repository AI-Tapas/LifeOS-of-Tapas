# Copy to .env.local for local dev. Get local Supabase values from: supabase status
# For production (Vercel), use the Supabase cloud project's values.

# --- Supabase -------------------------------------------------------------
# Supabase project URL (local: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key. Safe for the client; RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER SIDE ONLY, never expose to the client and never
# set it as a NEXT_PUBLIC_ variable. From Milestone 2 the server needs it to
# read/write OAuth tokens in Vault (lib/supabase/service.ts) and by
# scripts/rls.test.mjs. On Vercel set it as a plain (non-public) env var.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ------------------------------------------------------------------
# Public base URL of this app. Used to build OAuth redirect URIs, so it must
# exactly match what is registered in the Google/Microsoft consoles.
# Local: http://localhost:3000  (use localhost, not 127.0.0.1). Prod: the Vercel URL.
APP_BASE_URL=http://localhost:3000

# --- Google OAuth (app-level account connections, not Supabase sign-in) ----
# Two clients are mandatory: an Internal-audience client cannot serve accounts
# outside its org, so the Internal client serves Tax Strategia and the External
# client serves the consumer (ca.tapasnr) and icai.org accounts.
#
# Client A: Internal audience, Tax Strategia org project, client ID marked
# Trusted in the Workspace Admin console.
GOOGLE_INTERNAL_CLIENT_ID=
GOOGLE_INTERNAL_CLIENT_SECRET=
# Client B: External audience, publishing status Production, deliberately
# unverified (personal-use exception; click through the warning once).
GOOGLE_EXTERNAL_CLIENT_ID=
GOOGLE_EXTERNAL_CLIENT_SECRET=

# --- Microsoft OAuth -------------------------------------------------------
# Altechon single-tenant Entra app registration (delegated permissions, admin
# consent already granted). Tenant id pins sign-in to the Altechon tenant.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
